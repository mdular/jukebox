JUKEBOX_ENV=development
JUKEBOX_LOG_LEVEL=INFO
JUKEBOX_LOG_FORMAT=console
JUKEBOX_PLAYBACK_BACKEND=stub
JUKEBOX_DUPLICATE_WINDOW_SECONDS=2.0

