# Copy to /etc/jukebox/jukebox.env on the Raspberry Pi and fill in the real values.

JUKEBOX_ENV=production
JUKEBOX_LOG_LEVEL=INFO
JUKEBOX_LOG_FORMAT=json

JUKEBOX_INPUT_BACKEND=evdev
JUKEBOX_SCANNER_DEVICE=/dev/input/by-id/your-scanner-event-kbd

JUKEBOX_PLAYBACK_BACKEND=spotify
JUKEBOX_DUPLICATE_WINDOW_SECONDS=5.0

# Controller playback scopes:
# - user-read-playback-state
# - user-modify-playback-state
JUKEBOX_SPOTIFY_CLIENT_ID=
JUKEBOX_SPOTIFY_CLIENT_SECRET=
JUKEBOX_SPOTIFY_REFRESH_TOKEN=
JUKEBOX_SPOTIFY_TARGET_DEVICE_NAME=jukebox
# Optional override for troubleshooting only.
# JUKEBOX_SPOTIFY_DEVICE_ID=

JUKEBOX_SPOTIFY_CONFIRM_TIMEOUT_SECONDS=5.0
JUKEBOX_SPOTIFY_CONFIRM_POLL_INTERVAL_SECONDS=0.25
JUKEBOX_HEALTH_POLL_INTERVAL_SECONDS=5.0

JUKEBOX_OPERATOR_HTTP_BIND=0.0.0.0
JUKEBOX_OPERATOR_HTTP_PORT=8080
JUKEBOX_OPERATOR_STATE_PATH=/var/lib/jukebox/state.json

JUKEBOX_CONTROL_DEBOUNCE_SECONDS=1.0
JUKEBOX_PLAYBACK_MODE_DEFAULT=replace
JUKEBOX_VOLUME_PRESET_LOW_PERCENT=50
JUKEBOX_VOLUME_PRESET_MEDIUM_PERCENT=66
JUKEBOX_VOLUME_PRESET_HIGH_PERCENT=90

# Leave unset to disable idle shutdown.
# JUKEBOX_IDLE_SHUTDOWN_SECONDS=3600

JUKEBOX_SETUP_AP_SSID=
# Optional WPA2 passphrase for the setup AP.
# JUKEBOX_SETUP_AP_PASSPHRASE=
JUKEBOX_SETUP_FALLBACK_GRACE_SECONDS=120
JUKEBOX_WIFI_ROLLBACK_TIMEOUT_SECONDS=120

JUKEBOX_WIFI_HELPER_COMMAND=/usr/local/libexec/jukebox-wifi-helper
JUKEBOX_SPOTIFYD_AUTH_HELPER_COMMAND=/usr/local/libexec/jukebox-spotifyd-auth-helper
JUKEBOX_SHUTDOWN_HELPER_COMMAND=/usr/local/libexec/jukebox-shutdown-helper
